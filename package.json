{
  "name": "leowajda.github.io",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "docs:refresh": "tsx tools/src/main.ts docs",
    "sync:sources": "tsx tools/src/main.ts sync-sources",
    "generate": "tsx tools/src/main.ts generate",
    "generate:refresh-graphs": "tsx tools/src/main.ts generate --refresh-graphs",
    "build:css": "tailwindcss -i styles/main.css -o site/assets/css/main.css",
    "preview": "tsx tools/src/main.ts preview",
    "build:site": "pnpm generate && bundle exec jekyll build --source site --destination _site",
    "build:site:refresh-graphs": "pnpm generate:refresh-graphs && bundle exec jekyll build --source site --destination _site",
    "serve": "pnpm generate && bundle exec jekyll serve --source site --destination _site --livereload",
    "typecheck": "tsc --noEmit",
    "test:tools": "node --import tsx --test tools/test/**/*.test.ts"
  },
  "dependencies": {
    "@effect/cli": "^0.75.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "@effect/printer": "^0.49.0",
    "@effect/printer-ansi": "^0.49.0",
    "@effect/typeclass": "^0.40.0",
    "@sourcegraph/scip-python": "0.6.6",
    "effect": "^3.13.8",
    "esbuild": "^0.25.2",
    "katex": "^0.16.22",
    "protobufjs": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^22.13.13",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
